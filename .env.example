# ─── Auth Backend ────────────────────────────────────────────────────────────
# Base URL for your REST API (no trailing slash)
EXPO_PUBLIC_AUTH_BASE_URL=https://your-api.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Web client ID from Google Cloud Console (OAuth 2.0 → Web application)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# iOS client ID — also used as the reversed client ID for URL scheme
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=

# ─── Facebook ─────────────────────────────────────────────────────────────────
# App ID from Meta Developer Portal
EXPO_PUBLIC_FACEBOOK_APP_ID=

# ─── Expo / EAS ───────────────────────────────────────────────────────────────
# Your Expo project ID (from `eas init` or expo.dev dashboard)
EXPO_PUBLIC_PROJECT_ID=YOUR_EXPO_PROJECT_ID

# ─── Phone / OTP ──────────────────────────────────────────────────────────────
# No client-side keys needed — your backend handles the OTP provider (Twilio, etc.)
# Just make sure your backend exposes POST /auth/otp/send and POST /auth/otp/verify
